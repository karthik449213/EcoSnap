{
  "expo": {
    "name": "EcoSnap",
    "slug": "ecosnap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/EcoSnap.png",
    "scheme": "ecosnap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.ecosnap.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/EcoSnap.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/EcoSnap.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/EcoSnap.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E9F7EF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "26021e56-9842-44ed-b541-b25b4d04429f"
      }
    }
  }
}
